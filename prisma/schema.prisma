generator client {
  provider = "prisma-client-js"
  output   = "../server/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id             Int       @id @default(autoincrement())
  firstName      String
  lastName       String
  email          String
  phone          String
  clientType     String
  services       String
  description    String
  teamSize       String
  budget         String
  timelineMonths Int?
  timelineWeeks  Int?
  timelineDays   Int?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  client         Client?
}

model Admin {
  id                 Int       @id @default(autoincrement())
  username           String    @unique
  email              String?   @unique
  passwordHash       String
  tempPasswordHash   String?
  tempPasswordExpiry DateTime?
  mustChangePassword Boolean   @default(false)
  role               String    @default("ADMIN") // ADMIN | CLIENT | VIEWER
  isActive           Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  sessions           Session[]
}

model Session {
  id           Int       @id @default(autoincrement())
  adminId      Int
  admin        Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  refreshToken String    @unique // stored as bcrypt hash
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  ipAddress String
  username  String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([ipAddress, createdAt])
}

model Client {
  id           Int           @id @default(autoincrement())
  firstName    String
  lastName     String
  title        String?
  email        String
  phone        String?
  website      String?
  organization String?
  instagram    String?
  twitter      String?
  linkedin     String?
  facebook     String?
  notes        String?
  submissionId Int?          @unique
  submission   Submission?   @relation(fields: [submissionId], references: [id])
  projectScope ProjectScope?
  tasks        KanbanTask[]
  standing     ClientStanding?
  payments     PaymentEntry[]
  invoices     Invoice[]
  documents    ClientDocument[]
  deals        Deal[]
  discoveryQuestionnaire DiscoveryQuestionnaire?
  onboarding           ClientOnboarding?
  packageSelection     PackageSelection?
  adminCustomPackage   AdminCustomPackage?
  passwordHash         String?
  portalPasswordPlain  String?
  portalActive         Boolean   @default(false)
  lastLoginAt          DateTime?
  journeyPhase         String?   @default("discovery")
  upfrontDiscountPct   Float?    @default(0)
  messages             Message[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ClientDocument {
  id          Int      @id @default(autoincrement())
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fileName    String
  storedName  String
  docType     String
  mimeType    String
  size        Int
  createdAt   DateTime @default(now())
}

model ProjectScope {
  id             Int      @id @default(autoincrement())
  clientId       Int      @unique
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectName    String?
  projectType    String?
  services       String?
  budget         String?
  timeline       String?
  goals          String?
  targetAudience String?
  competitors    String?
  techStack      String?
  deliverables   String?
  notes          String?
  startDate      String?
  endDate        String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model KanbanTask {
  id          Int      @id @default(autoincrement())
  clientId    Int?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  column      String   @default("backlog")
  priority    String   @default("medium")
  dueDate     String?
  order       Int      @default(0)
  taskOwner   String   @default("admin")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClientStanding {
  id            Int      @id @default(autoincrement())
  clientId      Int      @unique
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  currency      String   @default("USD")
  totalContract Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PaymentEntry {
  id           Int      @id @default(autoincrement())
  clientId     Int
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  label        String
  amount       Float
  dueDate      String
  status       String   @default("pending")
  paidDate     String?
  rearrangedTo String?
  notes        String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Proposal {
  id               Int       @id @default(autoincrement())
  proposalNumber   String
  title            String
  status           String    @default("draft")
  clientName       String
  clientEmail      String
  clientPhone      String?
  clientCompany    String?
  clientAddress    String?
  clientId         Int?
  submissionId     Int?
  date             String
  validUntil       String?
  executiveSummary String?
  clientNeeds      String?
  proposedSolution String?
  projectScope     String?
  deliverables     String?
  timeline         String?
  lineItems        String?
  subtotal         Float     @default(0)
  discountType     String    @default("fixed")
  discountValue    Float     @default(0)
  taxRate          Float     @default(0)
  total            Float     @default(0)
  currency         String    @default("USD")
  paymentTerms     String?
  termsConditions  String?
  notes            String?
  sentAt           DateTime?
  signingToken     String?   @unique
  clientSignature  String?
  clientSignedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Invoice {
  id               Int      @id @default(autoincrement())
  clientId         Int
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceNumber    String
  title            String?
  lineItems        String?
  currency         String   @default("USD")
  subtotal         Float    @default(0)
  discountType     String   @default("fixed")
  discountValue    Float    @default(0)
  taxRate          Float    @default(0)
  amount           Float    @default(0)
  issuedDate       String
  dueDate          String
  status           String   @default("draft")
  notes            String?
  termsConditions  String?
  stripeInvoiceId  String?
  stripeInvoiceUrl String?
  stripeStatus     String?
  sentAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AdminSettings {
  id                Int      @id @default(autoincrement())
  stripeSecretKey      String?
  stripePublishableKey String?
  stripeWebhookSecret  String?
  gaPropertyId      String?
  gaCredentials     String?
  gaMeasurementId   String?
  smtpHost          String?
  smtpPort          String?
  smtpUser          String?
  smtpPass          String?
  smtpFrom          String?
  smtpSecure        Boolean  @default(false)
  recoveryEmail1    String?
  recoveryEmail2    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Deal {
  id           Int      @id @default(autoincrement())
  title        String
  company      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  value        Float    @default(0)
  stage        String   @default("lead")
  notes        String?
  clientId     Int?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AutomationRule {
  id              Int             @id @default(autoincrement())
  name            String
  type            String
  enabled         Boolean         @default(false)
  delayDays       Int             @default(3)
  subject         String?
  body            String?
  templateId      Int?
  targetClientIds String?         // JSON array of client IDs, null = all matching clients
  dedupeEnabled   Boolean         @default(false)
  dedupeDays      Int             @default(30)
  lastRunAt       DateTime?
  runCount        Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  logs            AutomationLog[]
}

model EmailTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  subject     String
  htmlContent String
  cssContent  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AutomationLog {
  id        Int            @id @default(autoincrement())
  ruleId    Int
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  status    String
  message   String?
  sentTo    String?
  createdAt DateTime       @default(now())
}

model Expense {
  id          Int      @id @default(autoincrement())
  title       String
  amount      Float
  category    String   @default("other")
  date        String
  notes       String?
  recurring   Boolean  @default(false)
  frequency   String?
  receiptPath String?
  receiptName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   // 'submission' | 'email_sent' | 'file_uploaded' | 'invoice_sent' | 'invoice_paid' | 'message'
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SentEmailLog {
  id           Int      @id @default(autoincrement())
  toEmail      String
  subject      String
  body         String?
  templateId   Int?
  templateName String?
  status       String   @default("sent")
  createdAt    DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  clientId  Int
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fromAdmin Boolean  @default(false)
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DiscoveryQuestionnaire {
  id          Int       @id @default(autoincrement())
  clientId    Int       @unique
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  section1    String?   // About Your Business
  section2    String?   // Goals & Objectives
  section3    String?   // Your Audience
  section4    String?   // Brand Identity & Visual Style
  section5    String?   // Website Vision
  section6    String?   // Design Inspiration
  section7    String?   // Mobile & User Experience
  section8    String?   // Content & Messaging
  section9    String?   // SEO & Growth
  section10   String?   // Technical Details
  section11   String?   // Timeline & Budget
  section12   String?   // Collaboration & Expectations
  section13   String?   // Final Vision
  status      String    @default("not_started")
  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ClientOnboarding {
  id                   Int       @id @default(autoincrement())
  clientId             Int       @unique
  client               Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  step1Questionnaire   Boolean   @default(false)
  step2BrandGuide      Boolean   @default(false)
  step3Package         Boolean   @default(false)
  step4Checkout        Boolean   @default(false)
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model PackageSelection {
  id          Int      @id @default(autoincrement())
  clientId    Int      @unique
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tier        String
  lineItems   String
  subtotal    Float    @default(0)
  total       Float    @default(0)
  notes       String?
  proposalId  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminCustomPackage {
  id           Int      @id @default(autoincrement())
  clientId     Int      @unique
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enabled      Boolean  @default(false)
  lineItems    String   @default("[]")
  subtotal     Float    @default(0)
  discountPct  Float    @default(0)
  total        Float    @default(0)
  notes            String?
  paymentTerms     String?
  bundleName       String?
  bundleType       String   @default("catalog")
  bundleExpiresAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CalendarEvent {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean   @default(false)
  eventType   String    @default("reminder")
  clientId    Int?
  color       String    @default("#18181b")
  reminders   String    @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
